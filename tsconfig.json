{
    "compilerOptions": {
        "strict": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "module": "nodenext",
        "target": "es2022",
        "moduleResolution": "nodenext",
        "verbatimModuleSyntax": true,
        "sourceMap": true,
        "outDir": "dist"
    },
    "exclude": [],
    "include": [
        "*.ts",
        "routes/",
        "test/",
        "lib/"
    ]
}
